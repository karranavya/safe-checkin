# ==========================================
# Core Ignores (Environment & Dependencies)
# ==========================================

# Ignore Node modules globally or inside subfolders
node_modules/
**/node_modules/

# Ignore local environment variable files (secrets)
.env
.env.*
!.env.example
**/.env
**/.env.*

# Python Virtual Environments (FastAPI)
venv/
.venv/
env/
ENV/
pyenv/

# ==========================================
# Python & FastAPI Clean Up
# ==========================================
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/

# ==========================================
# Frontend / Backend Build Outputs
# ==========================================
dist/
build/
.next/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================================
# Editor & OS Files
# ==========================================
.vscode/
.idea/
.DS_Store
Thumbs.db

# ========== SERVER CONFIGURATION ========== #
PORT=5000
NODE_ENV=development
API_URL=http://localhost:5000

# ========== DATABASE CONFIGURATION ========== #
MONGODB_URI=mongodb+srv://karranavyanagalakshmi:nishunavya123@cluster0.zsze8.mongodb.net/safecheckin?retryWrites=true&w=majority
MONGODB_MAX_POOL_SIZE=10
MONGODB_TIMEOUT=30000

# ========== JWT CONFIGURATION ========== #
JWT_SECRET=your-super-secret-jwt-key-here-make-it-very-long-and-random-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ========== CORS CONFIGURATION ========== #
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8081

# ========== RATE LIMITING ========== #
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========== FILE UPLOAD CONFIGURATION ========== #
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,video/mp4,application/pdf

# ========== LOGGING CONFIGURATION ========== #
LOG_LEVEL=debug
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14

# ========== EMAIL CONFIGURATION ========== #
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=noreply@safecheckin.com

# ========== SMS CONFIGURATION ========== #
# SMS_PROVIDER=twilio
# SMS_ACCOUNT_SID=your-account-sid
# SMS_AUTH_TOKEN=your-auth-token
# SMS_PHONE_NUMBER=+1234567890

# ========== PAYMENT CONFIGURATION (Future) ========== #
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ========== THIRD-PARTY APIs ========== #
# GOOGLE_MAPS_API_KEY=your-api-key
# TWILIO_API_KEY=your-api-key

# ========== SECURITY ========== #
BCRYPT_ROUNDS=10
SESSION_SECRET=your-session-secret-key

# ========== CACHE CONFIGURATION ========== #
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600

# ========== FEATURE FLAGS ========== #
ENABLE_SUSPECT_TRACKING=true
ENABLE_EVIDENCE_UPLOAD=true
ENABLE_ACTIVITY_LOGGING=true
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_SMS_NOTIFICATIONS=false
